      <aliases enabled='yes' />
      <column caption='OP18b Score' datatype='real' name='[Calculation_1903896748733259776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [measure_id] = &apos;OP_18b&apos; THEN [score] END' />
      </column>
      <column caption='Admit Wait' datatype='real' name='[Calculation_1903896748734562305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [measure_id] = &apos;ED_2_Strata_1&apos; THEN [score] END' />
      </column>
      <column caption='Discharge Wait' datatype='real' name='[Calculation_1903896748734640130]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [measure_id] = &apos;OP_18b&apos; THEN [score] END' />
      </column>
      <column caption='Worst State Flag' datatype='string' name='[Calculation_1903896748817395715]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1903896748734640130]) = WINDOW_MAX(AVG([Calculation_1903896748734640130]))&#10;THEN MIN([state])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='High Risk State' datatype='integer' name='[Calculation_1903896748820656133]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF AVG([Calculation_1903896748734562305]) &gt; WINDOW_AVG(AVG([Calculation_1903896748734562305]))&#10;AND AVG([Calculation_1903896748734640130]) &gt; WINDOW_AVG(AVG([Calculation_1903896748734640130]))&#10;THEN 1&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
